{
  "name": "bot-whatsapp-node",
  "version": "1.0.0",
  "description": "WhatsApp Bot — NestJS Migration",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "test": "vitest",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "build:css": "tailwindcss -i ./public/assets/css/tailwind-input.css -o ./public/assets/css/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./public/assets/css/tailwind-input.css -o ./public/assets/css/tailwind.css --watch"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/s3-request-presigner": "^3.750.0",
    "@bull-board/api": "^6.5.0",
    "@bull-board/fastify": "^6.5.0",
    "@bull-board/nestjs": "^6.5.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/view": "^10.0.0",
    "@nestjs/axios": "^4.0.0",
    "@nestjs/bullmq": "^11.0.0",
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/platform-fastify": "^11.1.0",
    "@nestjs/serve-static": "^5.0.0",
    "axios": "^1.7.0",
    "bullmq": "^5.66.0",
    "chart.js": "^4.5.1",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.45.0",
    "fastify": "^5.2.0",
    "form-data": "^4.0.0",
    "handlebars": "^4.7.0",
    "ioredis": "^5.9.0",
    "mammoth": "^1.8.0",
    "mysql2": "^3.12.0",
    "nestjs-pino": "^4.2.0",
    "pdf-parse-fork": "^1.2.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@tailwindcss/cli": "^4.2.1",
    "@types/handlebars": "^4.1.0",
    "@types/node": "^22.0.0",
    "@types/pdf-parse": "^1.1.0",
    "drizzle-kit": "^0.31.0",
    "pino-pretty": "^13.0.0",
    "tailwindcss": "^4.2.1",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
