<div style="max-width:42rem;margin:0 auto;">

    <!-- Progress bar -->
    <div style="margin-bottom:2rem;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.625rem;">
            <h1 style="font-size:1.5rem;font-weight:700;color:var(--text-primary);line-height:1.3;">Configuración Inicial</h1>
            <span id="progress-label" style="font-size:0.875rem;font-weight:500;color:var(--text-muted);">Paso 1 de 7</span>
        </div>
        <div style="width:100%;height:8px;background:var(--bg-elevated);border-radius:9999px;overflow:hidden;">
            <div id="progress-bar" style="height:100%;width:0%;background:var(--color-primary);border-radius:9999px;transition:width 0.5s ease;"></div>
        </div>
        <div id="step-indicators" style="display:flex;justify-content:space-between;margin-top:0.5rem;"></div>
    </div>

    <!-- Step panels -->
    <div id="wizard-container">
        <div style="text-align:center;padding:4rem 1rem;">
            <div class="spinner spinner-lg" style="margin:0 auto 1rem;"></div>
            <p style="color:var(--text-muted);">Cargando configuración...</p>
        </div>
    </div>

</div>
