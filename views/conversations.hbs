<h2 class="mb-4"><i class="bi bi-chat-dots me-2"></i>Conversaciones</h2>

<div class="row">
  <div class="col-md-5">
    <div class="card border-0 shadow-sm" style="height: 75vh;">
      <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <span class="fw-bold">Lista</span>
        <select id="status-filter" class="form-select form-select-sm" style="width: auto;">
          <option value="">Todas</option>
          <option value="active">Activas</option>
          <option value="closed">Cerradas</option>
        </select>
      </div>
      <div class="card-body p-0 overflow-auto" id="conv-list">
        <div class="text-center text-muted py-4">Cargando...</div>
      </div>
    </div>
  </div>
  <div class="col-md-7">
    <div class="card border-0 shadow-sm" style="height: 75vh;">
      <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <span class="fw-bold" id="chat-title">Selecciona una conversación</span>
        <button class="btn btn-sm btn-outline-secondary d-none" id="toggle-ai-btn">Toggle AI</button>
      </div>
      <div class="card-body overflow-auto d-flex flex-column-reverse" id="chat-messages" style="background: #e5ddd5;">
        <div class="text-center text-muted py-5">Selecciona una conversación para ver los mensajes</div>
      </div>
    </div>
  </div>
</div>

<script>
let currentConvId = null;

document.addEventListener('DOMContentLoaded', () => {
  loadConversations();
  document.getElementById('status-filter').addEventListener('change', loadConversations);
});

async function loadConversations(page = 1) {
  const status = document.getElementById('status-filter').value;
  const url = `/api/conversations?page=${page}${status ? '&status=' + status : ''}`;
  try {
    const res = await fetch(url);
    const data = await res.json();
    const list = document.getElementById('conv-list');
    if (data.success && data.data.conversations && data.data.conversations.length > 0) {
      list.innerHTML = data.data.conversations.map(c => `
        <div class="p-3 border-bottom conv-item ${c.id === currentConvId ? 'bg-light' : ''}" style="cursor:pointer;" onclick="selectConv(${c.id}, '${(c.contactName || 'Sin nombre').replace(/'/g, "\\'")}', ${c.aiEnabled})">
          <div class="d-flex justify-content-between">
            <strong>${c.contactName || 'Sin nombre'}</strong>
            <small class="text-muted">${c.lastMessageAt ? new Date(c.lastMessageAt).toLocaleDateString('es-CO') : ''}</small>
          </div>
          <small class="text-muted">${c.userPhone}</small>
          <span class="badge ${c.aiEnabled ? 'bg-success' : 'bg-secondary'} ms-2">${c.aiEnabled ? 'AI' : 'Manual'}</span>
        </div>
      `).join('');
    } else {
      list.innerHTML = '<div class="text-center text-muted py-4">No hay conversaciones</div>';
    }
  } catch (e) { console.error(e); }
}

async function selectConv(id, name, aiEnabled) {
  currentConvId = id;
  document.getElementById('chat-title').textContent = name;
  const btn = document.getElementById('toggle-ai-btn');
  btn.classList.remove('d-none');
  btn.textContent = aiEnabled ? 'Desactivar AI' : 'Activar AI';
  btn.onclick = () => toggleAI(id, !aiEnabled);
  loadConversations();
  try {
    const res = await fetch(`/api/conversations/${id}/messages`);
    const data = await res.json();
    const container = document.getElementById('chat-messages');
    if (data.success && data.data.length > 0) {
      container.innerHTML = data.data.map(m => `
        <div class="mb-2 d-flex ${m.senderType === 'user' ? 'justify-content-start' : 'justify-content-end'}">
          <div class="p-2 rounded-3 shadow-sm" style="max-width:75%; background: ${m.senderType === 'user' ? '#fff' : '#dcf8c6'};">
            <div style="white-space: pre-wrap;">${m.messageText}</div>
            <div class="text-end"><small class="text-muted">${new Date(m.createdAt).toLocaleTimeString('es-CO', {hour:'2-digit',minute:'2-digit'})}</small></div>
          </div>
        </div>
      `).join('');
    } else {
      container.innerHTML = '<div class="text-center text-muted py-5">Sin mensajes</div>';
    }
  } catch (e) { console.error(e); }
}

async function toggleAI(id, enabled) {
  await fetch(`/api/conversations/${id}/toggle-ai`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ enabled })
  });
  const btn = document.getElementById('toggle-ai-btn');
  btn.textContent = enabled ? 'Desactivar AI' : 'Activar AI';
  btn.onclick = () => toggleAI(id, !enabled);
  loadConversations();
}
</script>
