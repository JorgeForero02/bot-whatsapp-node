<h2 class="mb-4"><i class="bi bi-key me-2"></i>Credenciales</h2>

<div class="row">
  <div class="col-md-8">
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white fw-bold"><i class="bi bi-whatsapp me-1 text-success"></i> WhatsApp Business API</div>
      <div class="card-body">
        <div class="mb-3">
          <label class="form-label">Access Token</label>
          <input type="password" class="form-control" id="wa-access-token" placeholder="EAAxxxxxxx...">
        </div>
        <div class="mb-3">
          <label class="form-label">Phone Number ID</label>
          <input type="text" class="form-control" id="wa-phone-id" placeholder="1234567890">
        </div>
        <div class="mb-3">
          <label class="form-label">Verify Token</label>
          <input type="text" class="form-control" id="wa-verify-token" placeholder="your_verify_token">
        </div>
        <div class="mb-3">
          <label class="form-label">App Secret</label>
          <input type="password" class="form-control" id="wa-app-secret" placeholder="abc123...">
        </div>
        <button class="btn btn-success" onclick="saveWhatsApp()">
          <i class="bi bi-check-lg me-1"></i> Guardar WhatsApp
        </button>
        <div id="wa-status" class="mt-2"></div>
      </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white fw-bold"><i class="bi bi-cpu me-1 text-primary"></i> OpenAI</div>
      <div class="card-body">
        <div class="mb-3">
          <label class="form-label">API Key</label>
          <input type="password" class="form-control" id="openai-key" placeholder="sk-xxxxxxx...">
        </div>
        <button class="btn btn-primary" onclick="saveOpenAI()">
          <i class="bi bi-check-lg me-1"></i> Guardar OpenAI
        </button>
        <div id="openai-status" class="mt-2"></div>
      </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white fw-bold"><i class="bi bi-google me-1 text-danger"></i> Google Calendar OAuth</div>
      <div class="card-body">
        <div class="row mb-3">
          <div class="col-md-6">
            <label class="form-label">Client ID</label>
            <input type="text" class="form-control" id="g-client-id">
          </div>
          <div class="col-md-6">
            <label class="form-label">Client Secret</label>
            <input type="password" class="form-control" id="g-client-secret">
          </div>
        </div>
        <div class="mb-3">
          <label class="form-label">Access Token</label>
          <input type="password" class="form-control" id="g-access-token">
        </div>
        <div class="mb-3">
          <label class="form-label">Refresh Token</label>
          <input type="password" class="form-control" id="g-refresh-token">
        </div>
        <div class="mb-3">
          <label class="form-label">Calendar ID</label>
          <input type="text" class="form-control" id="g-calendar-id" placeholder="primary" value="primary">
        </div>
        <button class="btn btn-danger" onclick="saveGoogle()">
          <i class="bi bi-check-lg me-1"></i> Guardar Google
        </button>
        <div id="google-status" class="mt-2"></div>
      </div>
    </div>
  </div>
</div>

<script>
async function saveWhatsApp() {
  const res = await fetch('/api/credentials/whatsapp', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      accessToken: document.getElementById('wa-access-token').value,
      phoneNumberId: document.getElementById('wa-phone-id').value,
      verifyToken: document.getElementById('wa-verify-token').value,
      appSecret: document.getElementById('wa-app-secret').value,
    })
  });
  const data = await res.json();
  document.getElementById('wa-status').innerHTML = data.success
    ? '<div class="alert alert-success py-1">Guardado (encriptado)</div>'
    : '<div class="alert alert-danger py-1">Error</div>';
}

async function saveOpenAI() {
  const res = await fetch('/api/credentials/openai', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ apiKey: document.getElementById('openai-key').value })
  });
  const data = await res.json();
  document.getElementById('openai-status').innerHTML = data.success
    ? '<div class="alert alert-success py-1">Guardado (encriptado)</div>'
    : '<div class="alert alert-danger py-1">Error</div>';
}

async function saveGoogle() {
  const res = await fetch('/api/credentials/google', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      clientId: document.getElementById('g-client-id').value,
      clientSecret: document.getElementById('g-client-secret').value,
      accessToken: document.getElementById('g-access-token').value,
      refreshToken: document.getElementById('g-refresh-token').value,
      calendarId: document.getElementById('g-calendar-id').value,
    })
  });
  const data = await res.json();
  document.getElementById('google-status').innerHTML = data.success
    ? '<div class="alert alert-success py-1">Guardado (encriptado)</div>'
    : '<div class="alert alert-danger py-1">Error</div>';
}
</script>
