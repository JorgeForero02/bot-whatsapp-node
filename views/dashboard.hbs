<h2 class="mb-4"><i class="bi bi-speedometer2 me-2"></i>Dashboard</h2>

{{#if onboardingBanner}}
<div class="alert {{#if onboardingComplete}}alert-success{{else}}alert-warning{{/if}} d-flex align-items-center mb-4">
  <i class="bi {{#if onboardingComplete}}bi-check-circle{{else}}bi-exclamation-triangle{{/if}} me-2 fs-5"></i>
  {{#if onboardingComplete}}
    <span>¡Configuración completa! Tu bot está listo.</span>
  {{else}}
    <span>Configuración en progreso. <a href="/onboarding">Continuar configuración</a></span>
  {{/if}}
</div>
{{/if}}

<div class="row g-4 mb-4">
  <div class="col-md-3">
    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <div class="text-muted small">Conversaciones</div>
            <div class="fs-3 fw-bold" id="stat-conversations">—</div>
          </div>
          <i class="bi bi-chat-dots fs-2 text-primary"></i>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <div class="text-muted small">Mensajes hoy</div>
            <div class="fs-3 fw-bold" id="stat-messages-today">—</div>
          </div>
          <i class="bi bi-envelope fs-2 text-success"></i>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <div class="text-muted small">Documentos</div>
            <div class="fs-3 fw-bold" id="stat-documents">—</div>
          </div>
          <i class="bi bi-file-earmark-text fs-2 text-info"></i>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <div class="text-muted small">Activas</div>
            <div class="fs-3 fw-bold" id="stat-active">—</div>
          </div>
          <i class="bi bi-person-check fs-2 text-warning"></i>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-header bg-white fw-bold">Conversaciones recientes</div>
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr>
          <th>Contacto</th>
          <th>Teléfono</th>
          <th>Último mensaje</th>
          <th>Estado</th>
        </tr>
      </thead>
      <tbody id="recent-conversations">
        <tr><td colspan="4" class="text-center text-muted py-4">Cargando...</td></tr>
      </tbody>
    </table>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', async () => {
  try {
    const statsRes = await fetch('/api/dashboard-stats');
    const stats = await statsRes.json();
    if (stats.success) {
      document.getElementById('stat-conversations').textContent = stats.data.totalConversations ?? 0;
      document.getElementById('stat-messages-today').textContent = stats.data.messagesToday ?? 0;
      document.getElementById('stat-documents').textContent = stats.data.totalDocuments ?? 0;
      document.getElementById('stat-active').textContent = stats.data.activeConversations ?? 0;
    }
  } catch (e) { console.error('Failed to load stats', e); }

  try {
    const convRes = await fetch('/api/conversations?page=1');
    const conv = await convRes.json();
    const tbody = document.getElementById('recent-conversations');
    if (conv.success && conv.data.conversations && conv.data.conversations.length > 0) {
      tbody.innerHTML = conv.data.conversations.slice(0, 10).map(c => `
        <tr>
          <td><strong>${c.contactName || 'Sin nombre'}</strong></td>
          <td>${c.userPhone}</td>
          <td class="text-muted">${c.lastMessageAt ? new Date(c.lastMessageAt).toLocaleString('es-CO') : '—'}</td>
          <td><span class="badge ${c.aiEnabled ? 'bg-success' : 'bg-secondary'}">${c.aiEnabled ? 'AI' : 'Manual'}</span></td>
        </tr>
      `).join('');
    } else {
      tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-4">No hay conversaciones aún</td></tr>';
    }
  } catch (e) { console.error('Failed to load conversations', e); }
});
</script>
