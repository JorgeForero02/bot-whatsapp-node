<div class="page-header" style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:0.75rem;">
    <div>
        <h1 class="page-title">Constructor de Flujos</h1>
        <p class="page-subtitle">Define los flujos conversacionales del modo Bot Clásico</p>
    </div>
    <div style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;">
        <button onclick="exportFlow()" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
            Exportar
        </button>
        <label class="btn btn-secondary btn-sm" style="cursor:pointer;">
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l4-4m0 0l4 4m-4-4v12"/></svg>
            Importar
            <input type="file" accept=".json" style="display:none;" onchange="importFlow(event)">
        </label>
        <button onclick="openNodeModal()" class="btn btn-primary btn-sm">
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Nuevo Nodo
        </button>
    </div>
</div>

<div id="fb-main-grid" style="display:grid;grid-template-columns:1fr 300px;gap:1.25rem;align-items:start;">

    <div>
        <!-- Toolbar -->
        <div class="fb-toolbar">
            <div class="fb-search-wrap">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/></svg>
                <input id="fb-search" type="text" class="fb-search-input" placeholder="Buscar por nombre o keyword..." oninput="applyFilters()">
            </div>
            <div class="fb-filter-pills">
                <button class="fb-filter-pill active" data-filter="all" onclick="setFilter('all',this)">Todos</button>
                <button class="fb-filter-pill" data-filter="root" onclick="setFilter('root',this)">Raíz</button>
                <button class="fb-filter-pill" data-filter="calendar" onclick="setFilter('calendar',this)">Calendario</button>
                <button class="fb-filter-pill" data-filter="terminal" onclick="setFilter('terminal',this)">Terminales</button>
            </div>
            <div class="fb-view-toggle">
                <button class="fb-view-btn active" id="btn-view-list" onclick="setView('list')" title="Vista lista">
                    <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
                </button>
                <button class="fb-view-btn" id="btn-view-tree" onclick="setView('tree')" title="Vista árbol">
                    <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7h4m0 0v10m0-10h8m0 0v4m0-4h4M7 17h4"/></svg>
                </button>
            </div>
        </div>

        <!-- Meta bar -->
        <div class="fb-meta-bar">
            <span class="fb-node-count" id="fb-node-count">0 nodos</span>
            <span id="fb-filter-label"></span>
        </div>

        <!-- Nodes container -->
        <div id="nodes-container">
            <div style="text-align:center;padding:3rem 1rem;color:var(--text-muted);">
                <div class="spinner spinner-lg" style="margin:0 auto 1rem;"></div>
                <p>Cargando flujos...</p>
            </div>
        </div>
    </div>

    <!-- Simulator panel -->
    <div style="position:sticky;top:calc(var(--topbar-height) + 1rem);">
        <div class="fb-sim-panel">
            <div class="fb-sim-header">
                <span class="fb-sim-title">
                    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:var(--color-primary);flex-shrink:0;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                    Simulador
                </span>
            </div>
            <div class="fb-sim-chat" id="sim-chat">
                <div class="fb-sim-empty">Escribe un mensaje para simular la conversación</div>
            </div>
            <div class="fb-sim-footer">
                <div class="fb-sim-input-row">
                    <input id="sim-input" type="text" class="fb-sim-input" placeholder="Escribe un mensaje..." onkeydown="if(event.key==='Enter') sendSimMessage()">
                    <button class="fb-sim-send" onclick="sendSimMessage()">
                        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                    </button>
                </div>
                <button class="fb-sim-reset" onclick="resetSimulator()">↺ Reiniciar sesión</button>
            </div>
        </div>
    </div>
</div>

<style>
@media (max-width: 900px) {
  #fb-main-grid { grid-template-columns: 1fr !important; }
}
@media (max-width: 600px) {
  .fb-toggle-grid { grid-template-columns: 1fr !important; }
  .modal-box { max-height: 100vh !important; border-radius: var(--radius-xl) var(--radius-xl) 0 0 !important; }
}
</style>

<!-- Node Modal -->
<div id="node-modal" class="modal-backdrop" style="pointer-events:none;">
    <div class="modal-box modal-lg" style="height:90vh;max-height:90vh;">
        <div class="modal-header">
            <h2 id="modal-title" class="modal-title">Nuevo Nodo</h2>
            <button onclick="closeNodeModal()" class="modal-close" aria-label="Cerrar">
                <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>

        <div class="modal-body" style="display:flex;flex-direction:column;gap:0.5rem;">
            <input type="hidden" id="node-id">

            <!-- Section 1: Identity -->
            <div class="fb-form-section">
                <div class="fb-form-section-header" onclick="toggleFormSection(this)">
                    <span class="fb-form-section-title">1. Identidad</span>
                    <svg class="fb-form-section-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                </div>
                <div class="fb-form-section-body">
                    <div class="form-group">
                        <label class="form-label">Nombre del nodo <span style="color:var(--color-error);">*</span></label>
                        <input type="text" id="node-name" placeholder="Ej: Bienvenida, Menú Principal..." class="form-input">
                    </div>
                    <div class="fb-toggle-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
                        <div style="display:flex;align-items:center;justify-content:space-between;padding:0.5rem 0.75rem;background:var(--bg-elevated);border-radius:var(--radius-lg);border:1px solid var(--border-color);">
                            <div>
                                <p class="form-label" style="margin-bottom:0;">Nodo raíz</p>
                                <p class="form-hint" style="margin-top:0;">Sin contexto previo</p>
                            </div>
                            <label class="toggle" style="margin-left:0.5rem;">
                                <input type="checkbox" id="node-is-root" onchange="onIsRootChange()">
                                <span class="toggle-thumb"></span>
                            </label>
                        </div>
                        <div style="display:flex;align-items:center;justify-content:space-between;padding:0.5rem 0.75rem;background:rgba(147,51,234,0.05);border-radius:var(--radius-lg);border:1px solid rgba(147,51,234,0.2);">
                            <div>
                                <p class="form-label" style="margin-bottom:0;">Despedida</p>
                                <p class="form-hint" style="margin-top:0;">Cierra la conversación</p>
                            </div>
                            <label class="toggle toggle-purple" style="margin-left:0.5rem;">
                                <input type="checkbox" id="node-is-farewell">
                                <span class="toggle-thumb"></span>
                            </label>
                        </div>
                        <div style="display:flex;align-items:center;justify-content:space-between;padding:0.5rem 0.75rem;background:var(--bg-elevated);border-radius:var(--radius-lg);border:1px solid var(--border-color);">
                            <div>
                                <p class="form-label" style="margin-bottom:0;">Activo</p>
                                <p class="form-hint" style="margin-top:0;">Visible en el flujo</p>
                            </div>
                            <label class="toggle" style="margin-left:0.5rem;">
                                <input type="checkbox" id="node-is-active" checked>
                                <span class="toggle-thumb"></span>
                            </label>
                        </div>
                    </div>
                    <div id="match-any-input-row" class="hidden">
                        <div style="display:flex;align-items:center;justify-content:space-between;padding:0.5rem 0.75rem;background:rgba(249,115,22,0.05);border-radius:var(--radius-lg);border:1px solid rgba(249,115,22,0.2);">
                            <div>
                                <p class="form-label" style="margin-bottom:0.125rem;">Cualquier mensaje</p>
                                <p class="form-hint" style="margin-top:0;">Se dispara sin keywords específicas</p>
                            </div>
                            <label class="toggle toggle-orange" style="margin-left:0.5rem;">
                                <input type="checkbox" id="node-match-any-input" onchange="onMatchAnyInputChange()">
                                <span class="toggle-thumb"></span>
                            </label>
                        </div>
                        <div id="match-any-notice" class="hidden alert alert-warning" style="margin-top:0.5rem;font-size:0.75rem;">
                            Las palabras clave son ignoradas cuando este modo está activo.
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Orden de posición</label>
                        <input type="number" id="node-order" value="0" min="0" class="form-input" style="width:6rem;">
                    </div>
                </div>
            </div>

            <!-- Section 2: Activation -->
            <div class="fb-form-section">
                <div class="fb-form-section-header" onclick="toggleFormSection(this)">
                    <span class="fb-form-section-title">2. Activación — Keywords</span>
                    <svg class="fb-form-section-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                </div>
                <div class="fb-form-section-body">
                    <div class="form-group">
                        <div id="keywords-tags" style="display:flex;flex-wrap:wrap;gap:0.375rem;padding:0.5rem;border:1px solid var(--border-color);border-radius:var(--radius-md);background:var(--bg-surface);min-height:40px;margin-bottom:0.375rem;"></div>
                        <input type="text" id="keywords-input" placeholder="Escribe una keyword y presiona Enter o coma..." class="form-input" onkeydown="handleKeywordInput(event)">
                        <p class="form-hint">Presiona Enter o coma para agregar cada keyword</p>
                    </div>
                </div>
            </div>

            <!-- Section 3: Response -->
            <div class="fb-form-section">
                <div class="fb-form-section-header" onclick="toggleFormSection(this)">
                    <span class="fb-form-section-title">3. Respuesta</span>
                    <svg class="fb-form-section-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                </div>
                <div class="fb-form-section-body">
                    <div class="form-group">
                        <label class="form-label">Mensaje de respuesta <span style="color:var(--color-error);">*</span></label>
                        <textarea id="node-message" rows="4" placeholder="Escribe el mensaje que el bot enviará..." class="form-textarea" style="resize:vertical;"></textarea>
                        <div class="fb-char-counter" id="msg-char-counter">0 caracteres</div>
                    </div>
                    <div style="display:flex;align-items:center;justify-content:space-between;padding:0.5rem 0.75rem;background:var(--color-info-bg);border-radius:var(--radius-lg);border:1px solid var(--color-info-border);">
                        <div>
                            <p class="form-label" style="margin-bottom:0.125rem;color:var(--color-info);">Activa calendario</p>
                            <p class="form-hint" style="margin-top:0;">Delega al asistente de citas</p>
                        </div>
                        <label class="toggle toggle-blue" style="margin-left:0.5rem;">
                            <input type="checkbox" id="node-requires-calendar" onchange="onCalendarToggle()">
                            <span class="toggle-thumb"></span>
                        </label>
                    </div>
                    <div id="calendar-notice" class="hidden alert alert-info" style="font-size:0.75rem;">
                        Este nodo activará el flujo de agendamiento de citas cuando sea alcanzado.
                    </div>
                    <div id="message-preview" class="hidden">
                        <p class="form-hint" style="margin-bottom:0.375rem;">Vista previa:</p>
                        <div style="background:var(--color-success-bg);border:1px solid var(--color-success-border);border-radius:var(--radius-lg);padding:0.625rem 0.75rem;font-size:0.8125rem;color:var(--text-primary);white-space:pre-wrap;line-height:1.6;"></div>
                    </div>
                </div>
            </div>

            <!-- Section 4: Options -->
            <div class="fb-form-section">
                <div class="fb-form-section-header" onclick="toggleFormSection(this)">
                    <span class="fb-form-section-title">4. Opciones del menú</span>
                    <div style="display:flex;align-items:center;gap:0.5rem;margin-left:auto;margin-right:0.5rem;">
                        <button onclick="event.stopPropagation(); addOption()" type="button" class="btn btn-primary" style="font-size:0.75rem;padding:0.25rem 0.625rem;min-height:26px;">+ Agregar</button>
                    </div>
                    <svg class="fb-form-section-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                </div>
                <div class="fb-form-section-body">
                    <div id="options-container" style="display:flex;flex-direction:column;gap:0.5rem;"></div>
                    <div class="form-group">
                        <label class="form-label">Nodo siguiente (automático)</label>
                        <select id="node-next" class="form-select">
                            <option value="">— Ninguno —</option>
                        </select>
                        <p class="form-hint">Si ninguna opción coincide, el bot irá aquí</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal-footer">
            <button onclick="closeNodeModal()" class="btn btn-secondary btn-md">Cancelar</button>
            <button onclick="saveNode()" class="btn btn-primary btn-md">Guardar Nodo</button>
        </div>
    </div>
</div>
