<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}} — WhatsApp Bot Panel</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    body { background: #f4f6f9; }
    .sidebar { min-height: 100vh; background: #212529; }
    .sidebar .nav-link { color: #adb5bd; padding: 0.75rem 1.25rem; }
    .sidebar .nav-link:hover, .sidebar .nav-link.active { color: #fff; background: rgba(255,255,255,0.08); }
    .sidebar .nav-link i { width: 24px; }
    .content-area { padding: 1.5rem; }
    .onboarding-pill { font-size: 0.8rem; }
    .progress-mini { height: 6px; }
  </style>
</head>
<body>
  <div class="d-flex">
    <!-- Sidebar -->
    <nav class="sidebar d-flex flex-column p-3" style="width: 250px;">
      <a class="text-white text-decoration-none mb-4 d-flex align-items-center" href="/">
        <i class="bi bi-whatsapp fs-4 me-2"></i>
        <span class="fw-bold">WhatsApp Bot</span>
      </a>

      <ul class="nav flex-column">
        <li class="nav-item">
          <a class="nav-link {{#if isDashboard}}active{{/if}}" href="/">
            <i class="bi bi-speedometer2 me-2"></i> Dashboard
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link {{#if isConversations}}active{{/if}}" href="/conversations">
            <i class="bi bi-chat-dots me-2"></i> Conversaciones
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link {{#if isDocuments}}active{{/if}}" href="/documents">
            <i class="bi bi-file-earmark-text me-2"></i> Documentos
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link {{#if isSettings}}active{{/if}}" href="/settings">
            <i class="bi bi-gear me-2"></i> Configuración
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link {{#if isCalendarSettings}}active{{/if}}" href="/calendar-settings">
            <i class="bi bi-calendar3 me-2"></i> Calendario
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link {{#if isCredentials}}active{{/if}}" href="/credentials">
            <i class="bi bi-key me-2"></i> Credenciales
          </a>
        </li>
        {{#if showFlowBuilder}}
        <li class="nav-item">
          <a class="nav-link {{#if isFlowBuilder}}active{{/if}}" href="/flow-builder">
            <i class="bi bi-diagram-3 me-2"></i> Flujos
          </a>
        </li>
        {{/if}}
      </ul>

      {{#if onboarding}}
      <div class="mt-auto">
        <a href="/onboarding" class="text-decoration-none">
          <div class="bg-dark rounded p-2">
            <div class="d-flex justify-content-between text-white-50 onboarding-pill mb-1">
              <span>Onboarding</span>
              <span>{{onboarding.completed}}/{{onboarding.total}}</span>
            </div>
            <div class="progress progress-mini">
              <div class="progress-bar bg-success" style="width: {{onboarding.percent}}%"></div>
            </div>
          </div>
        </a>
      </div>
      {{/if}}
    </nav>

    <!-- Main Content -->
    <main class="content-area flex-grow-1">
      {{{body}}}
    </main>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
