# ──────────────────────────────────────
# App
# ──────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
APP_DEBUG=false
APP_CIPHER_KEY=your_32_character_cipher_key_here
API_PANEL_TOKEN=your_api_panel_token_here
BULL_BOARD_TOKEN=your_bull_board_token_here
VECTOR_SEARCH_LIMIT=300

# ──────────────────────────────────────
# Database (MySQL)
# ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=whatsapp_rag_bot
DB_USER=your_db_user_here
DB_PASSWORD=your_db_password_here

# ──────────────────────────────────────
# Redis
# ──────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────
# WhatsApp Business API
# ──────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token_here
APP_SECRET=your_whatsapp_app_secret_here

# ──────────────────────────────────────
# OpenAI
# ──────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# ──────────────────────────────────────
# Google Calendar OAuth
# ──────────────────────────────────────
GOOGLE_CALENDAR_ACCESS_TOKEN=your_google_access_token_here
GOOGLE_CALENDAR_REFRESH_TOKEN=your_google_refresh_token_here
GOOGLE_CALENDAR_CLIENT_ID=your_google_client_id_here
GOOGLE_CALENDAR_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALENDAR_ID=primary

# ──────────────────────────────────────
# Cloudflare R2 Storage
# ──────────────────────────────────────
CLOUDFLARE_R2_ACCOUNT_ID=your_r2_account_id_here
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id_here
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
CLOUDFLARE_R2_BUCKET_NAME=your_r2_bucket_name_here
CLOUDFLARE_R2_PUBLIC_URL=your_r2_public_url_here
